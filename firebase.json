{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/calculator",
        "destination": "/calculator/index.html"
      },
      {
        "source": "/calculator/**",
        "destination": "/calculator/index.html"
      }
    ]
  }
}
