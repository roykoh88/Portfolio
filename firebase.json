{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, max-age=0" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/calculator",
        "destination": "/calculator/index.html"
      },
      {
        "source": "/calculator/**",
        "destination": "/calculator/index.html"
      }
    ]
  }
}
